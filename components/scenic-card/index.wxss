.sc-card {
  margin-bottom: 14rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 6rpx 18rpx rgba(20, 42, 82, 0.09);
  background: #fff;
}

.sc-media {
  position: relative;
  width: 100%;
  background: #e9eef7;
}

.img-skeleton {
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, #edf2fb 25%, #f8fbff 37%, #edf2fb 63%);
  background-size: 400% 100%;
  animation: shimmer 1.2s infinite;
  z-index: 1;
}

.sc-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  opacity: 0;
  transform: scale(1.03);
  transition: opacity .35s ease, transform .35s ease;
  z-index: 2;
}

.sc-img.show {
  opacity: 1;
  transform: scale(1);
}

.sc-overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 42%;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, .7) 100%);
  z-index: 3;
}

.sc-meta {
  position: absolute;
  left: 14rpx;
  right: 14rpx;
  bottom: 14rpx;
  z-index: 4;
}

.sc-name {
  display: block;
  color: #fff;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.25;
  margin-bottom: 4rpx;
}

.sc-location {
  display: block;
  color: rgba(255, 255, 255, .88);
  font-size: 21rpx;
  margin-bottom: 8rpx;
}

.sc-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.sc-tag {
  font-size: 18rpx;
  color: #fff;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(25, 120, 255, .75);
  border: 1rpx solid rgba(255, 255, 255, .22);
}

@keyframes shimmer {
  0% { background-position: 100% 0; }
  100% { background-position: 0 0; }
}
