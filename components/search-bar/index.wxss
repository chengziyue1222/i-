.sb-wrap { padding:16rpx 24rpx; background:#fff; }
.sb-inner { display:flex; align-items:center; gap:12rpx; background:#f0f1f5; border-radius:40rpx; padding:18rpx 24rpx; }
.sb-icon { font-size:28rpx; flex-shrink:0; }
.sb-input { flex:1; font-size:28rpx; color:#333; }
.sb-ph { color:#bbb; }
.sb-clear { font-size:28rpx; color:#bbb; flex-shrink:0; padding:0 4rpx; }
