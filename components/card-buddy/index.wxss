.buddy-card {
  display: block;
  width: 100%;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 14rpx 36rpx rgba(17, 42, 84, 0.16);
  margin-bottom: 18rpx;
}

.buddy-card:active {
  transform: scale(0.985);
  opacity: 0.96;
}

.bc-cover-wrap {
  position: relative;
  width: 100%;
  height: 0;
  padding-bottom: 60%;
  background: linear-gradient(160deg, #9fd1ff 0%, #57b7ff 38%, #2e8cf0 100%);
}

.bc-cover {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.bc-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.08) 26%, rgba(0, 0, 0, 0.7) 100%);
}

.bc-top-badges {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  display: flex;
  gap: 8rpx;
  z-index: 3;
}

.bc-badge {
  font-size: 20rpx;
  font-weight: 700;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  color: #fff;
}

.bc-badge-green {
  background: linear-gradient(135deg, #24c26a, #10a54f);
  box-shadow: 0 6rpx 14rpx rgba(36, 194, 106, 0.35);
}

.bc-badge-red {
  background: linear-gradient(135deg, #ff5d5d, #f03e3e);
  box-shadow: 0 6rpx 14rpx rgba(240, 62, 62, 0.36);
}

.bc-cover-bottom {
  position: absolute;
  left: 16rpx;
  right: 16rpx;
  bottom: 12rpx;
  z-index: 2;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}

.bc-dest {
  font-size: 32rpx;
  font-weight: 800;
  color: #fff;
  text-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.25);
}

.bc-time {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.88);
  margin-left: 12rpx;
  flex-shrink: 0;
}

.bc-body {
  padding: 16rpx 16rpx 18rpx;
}

.bc-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.bc-title-main {
  font-size: 30rpx;
  font-weight: 700;
  color: #1e2a3d;
}

.bc-title-time {
  font-size: 22rpx;
  color: #7b889d;
}

.bc-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.bc-tag {
  font-size: 20rpx;
  color: #1464d9;
  background: #e8f2ff;
  padding: 5rpx 12rpx;
  border-radius: 999rpx;
}

.bc-user-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.bc-user {
  display: flex;
  align-items: center;
  min-width: 0;
  gap: 10rpx;
  flex: 1;
}

.bc-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #0f62fe, #2e90ff);
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.bc-user-meta {
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.bc-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #28374f;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.bc-sub {
  font-size: 20rpx;
  color: #3f7ae0;
  font-weight: 600;
}

.bc-status-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx 10rpx;
  margin-bottom: 12rpx;
}

.bc-status-item {
  font-size: 20rpx;
  color: #6d7a90;
  background: #f3f6fb;
  border-radius: 10rpx;
  padding: 4rpx 10rpx;
}

.bc-actions {
  display: flex;
  gap: 10rpx;
  margin-top: 12rpx;
}

.bc-btn {
  flex: 1;
  text-align: center;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.bc-btn-chat {
  background: #eef3fb;
  color: #3e5679;
}

.bc-btn-join {
  background: linear-gradient(135deg, #0f62fe, #228be6);
  color: #fff;
  box-shadow: 0 6rpx 14rpx rgba(15, 98, 254, 0.3);
}

.bc-reasons {
  margin-top: 10rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.bc-reason {
  font-size: 19rpx;
  color: #7a879b;
  background: #f3f6fb;
  padding: 4rpx 10rpx;
  border-radius: 10rpx;
}
