.buddy-card {
  display: block;
  width: 100%;
  background: #fff;
  border-radius: 22rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 30rpx rgba(27, 67, 122, 0.12);
  margin-bottom: 18rpx;
}

.buddy-card:active {
  transform: scale(0.985);
  opacity: 0.96;
}

.bc-cover-wrap {
  position: relative;
  width: 100%;
  height: 0;
  padding-bottom: 124%;
  background: linear-gradient(160deg, #9fd1ff 0%, #57b7ff 38%, #2e8cf0 100%);
}

.bc-cover {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.bc-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.05) 28%, rgba(0, 0, 0, 0.68) 100%);
}

.bc-status {
  position: absolute;
  top: 0;
  right: 0;
  min-width: 120rpx;
  text-align: center;
  font-size: 20rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
  padding: 10rpx 14rpx 10rpx 18rpx;
  border-radius: 0 20rpx 0 20rpx;
  z-index: 3;
  border-left: 2rpx solid rgba(255,255,255,.28);
  border-bottom: 2rpx solid rgba(255,255,255,.2);
}

.bc-status-recruiting {
  background: linear-gradient(135deg, #24c26a, #10a54f);
  color: #fff;
  box-shadow: 0 8rpx 18rpx rgba(36, 194, 106, 0.38);
}

.bc-status-full {
  background: linear-gradient(135deg, #6b7280, #4b5563);
  color: #eef2ff;
  box-shadow: 0 8rpx 18rpx rgba(75, 85, 99, 0.28);
}

.bc-cover-bottom {
  position: absolute;
  left: 16rpx;
  right: 16rpx;
  bottom: 14rpx;
  z-index: 2;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.bc-dest {
  font-size: 34rpx;
  font-weight: 800;
  color: #fff;
  text-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.25);
}

.bc-time {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.88);
}

.bc-body {
  padding: 14rpx 14rpx 16rpx;
}

.bc-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.bc-tag {
  font-size: 20rpx;
  color: #1464d9;
  background: #e8f2ff;
  padding: 5rpx 12rpx;
  border-radius: 999rpx;
}

.bc-user-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
}

.bc-user {
  display: flex;
  align-items: center;
  min-width: 0;
  gap: 10rpx;
  flex: 1;
}

.bc-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #0f62fe, #2e90ff);
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.bc-user-meta {
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.bc-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #28374f;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.bc-sub {
  font-size: 20rpx;
  color: #8392a9;
}

.bc-score {
  font-size: 22rpx;
  font-weight: 700;
  color: #0f62fe;
  background: #e7f0ff;
  border-radius: 999rpx;
  padding: 6rpx 12rpx;
  flex-shrink: 0;
}

.bc-actions {
  display: flex;
  gap: 10rpx;
  margin-top: 12rpx;
}

.bc-btn {
  flex: 1;
  text-align: center;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.bc-btn-chat {
  background: #eef3fb;
  color: #3e5679;
}

.bc-btn-join {
  background: linear-gradient(135deg, #1a75ff, #36a2ff);
  color: #fff;
}

.bc-reasons {
  margin-top: 10rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.bc-reason {
  font-size: 19rpx;
  color: #7a879b;
  background: #f3f6fb;
  padding: 4rpx 10rpx;
  border-radius: 10rpx;
}
