{
  "pages": [
    "pages/index/index",
    "pages/profile/index",
    "pages/post-detail/index",
    "pages/route/scenic-list",
    "pages/solution/index",
    "pages/community/index",
    "pages/community/detail/index",
    "pages/community/publish/index",
    "pages/aboutUs/index",
    "pages/news/index",
    "pages/scenic/index",
    "pages/detail/index",
    "pages/safety-center/index",
    "pages/settings/index",
    "pages/trip-library/index",
    "pages/tag-edit/index",
    "pages/buddy-match/index",
    "pages/buddy-apply/index",
    "pages/chat/index",
    "pages/buddy-detail/index",
    "pages/community-detail/index",
    "pages/message/index",
    "pages/post-comment/index"
  ],
  "subPackages": [
    {
      "root": "packageRoute/pages/route",
      "name": "route",
      "pages": [
        "scenic-detail",
        "route-plan",
        "route-map",
        "route-nav-page",
        "route-detail"
      ]
    }
  ],
  "window": {
    "backgroundColor": "#F6F6F6",
    "backgroundTextStyle": "light",
    "navigationBarBackgroundColor": "#F6F6F6",
    "navigationBarTitleText": "i旅图",
    "navigationBarTextStyle": "black",
    "navigationStyle": "default"
  },
  "sitemapLocation": "sitemap.json",
  "style": "v2",
  "lazyCodeLoading": "requiredComponents",
  "preloadRule": {
    "pages/index/index": {
      "network": "all",
      "packages": ["route"]
    },
    "pages/route/scenic-list": {
      "network": "all",
      "packages": ["route"]
    }
  },
  "permission": {
    "scope.userLocation": {
      "desc": "你的位置信息将用于小程序位置定位"
    }
  },
  "requiredPrivateInfos": [
    "getLocation"
  ],
  "tabBar": {
    "color": "#A2A9B0",
    "selectedColor": "#0F62FE",
    "backgroundColor": "#ffffff",
    "borderStyle": "black",
    "list": [
      {
        "pagePath": "pages/index/index",
        "text": "首页",
        "iconPath": "images/icons/index.png",
        "selectedIconPath": "images/icons/index-active.png"
      },
      {
        "pagePath": "pages/route/scenic-list",
        "text": "路线",
        "iconPath": "images/icons/route.png",
        "selectedIconPath": "images/icons/route-active.png"
      },
      {
        "pagePath": "pages/solution/index",
        "text": "旅游搭子",
        "iconPath": "images/icons/solution.png",
        "selectedIconPath": "images/icons/solution-active.png"
      },
      {
        "pagePath": "pages/message/index",
        "text": "消息",
        "iconPath": "images/icons/chat.png",
        "selectedIconPath": "images/icons/chat-active.png"
      },
      {
        "pagePath": "pages/profile/index",
        "text": "我的",
        "iconPath": "images/icons/about.png",
        "selectedIconPath": "images/icons/about-active.png"
      }
    ]
  },
  "usingComponents": {
    "card-buddy": "/components/card-buddy/index",
    "card-scenic": "/components/card-scenic/index",
    "search-bar": "/components/search-bar/index",
    "tab-switch": "/components/tab-switch/index"
  }
}
