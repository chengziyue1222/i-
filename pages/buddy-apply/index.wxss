.page { min-height:100vh; background:#f2f3f7; padding-bottom:160rpx; }

.summary { height:280rpx; position:relative; display:flex; align-items:flex-end; overflow:hidden; }
.s-emoji { position:absolute; top:40%; left:50%; transform:translate(-50%,-50%); font-size:80rpx; }
.s-overlay { position:absolute; inset:0; background:linear-gradient(to bottom,rgba(0,0,0,.1),rgba(0,0,0,.6)); }
.s-content { position:relative; z-index:1; padding:0 32rpx 28rpx; width:100%; box-sizing:border-box; }
.s-title { display:block; color:#fff; font-size:34rpx; font-weight:800; margin-bottom:12rpx; }
.s-meta { display:flex; flex-wrap:wrap; gap:12rpx; }
.s-item { font-size:24rpx; color:rgba(255,255,255,.9); background:rgba(255,255,255,.15); padding:6rpx 16rpx; border-radius:16rpx; }

.form-card { margin:24rpx 24rpx 0; background:#fff; border-radius:20rpx; padding:32rpx; box-shadow:0 4rpx 16rpx rgba(0,0,0,.05); }
.form-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:8rpx; }
.form-title { font-size:28rpx; font-weight:700; color:#1a1a1a; }
.req { color:#f03e3e; }
.form-count { font-size:22rpx; color:#bbb; }
.form-hint { display:block; font-size:24rpx; color:#999; margin-bottom:20rpx; }
.textarea { width:100%; min-height:200rpx; background:#f4f5f7; border-radius:12rpx; padding:20rpx 24rpx; font-size:28rpx; color:#333; box-sizing:border-box; line-height:1.7; }

.tips { margin:20rpx 24rpx 0; }
.tip { display:block; font-size:24rpx; color:#999; line-height:1.8; }

.footer { position:fixed; bottom:0; left:0; right:0; padding:20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom)); background:#fff; border-top:1rpx solid #eee; }
.btn-submit { background:linear-gradient(135deg,#0f62fe,#228be6); color:#fff; text-align:center; padding:28rpx; border-radius:16rpx; font-size:32rpx; font-weight:700; box-shadow:0 6rpx 20rpx rgba(15,98,254,.35); }
.btn-submit:active { opacity:.85; }
.btn-done { background:linear-gradient(135deg,#2b8a3e,#40c057) !important; box-shadow:0 6rpx 20rpx rgba(43,138,62,.35) !important; }
