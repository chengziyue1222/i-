/* pages/route/route-nav-page.wxss */
.nav-page-container {
  height: 100vh;
  position: relative;
  background-color: #f6f6f6;
}

.back-button {
  position: absolute;
  top: 40rpx;
  left: 30rpx;
  width: 80rpx;
  height: 80rpx;
  background-color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  z-index: 100;
}

