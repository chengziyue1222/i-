<!--pages/route/scenic-detail.wxml-->
<view class="scenic-detail-container">
  <!-- 景区头部信息 -->
  <view class="scenic-header">
    <image class="header-image" src="{{scenicInfo.images[0]}}" mode="aspectFill"></image>
    <view class="header-overlay">
      <text class="scenic-title">{{scenicInfo.scenicName}}</text>
      <text class="scenic-desc">{{scenicInfo.description}}</text>
    </view>
  </view>

  <!-- 景区信息 -->
  <view class="scenic-info-card">
    <view class="info-row">
      <text class="info-label">开放时间</text>
      <text class="info-value">{{scenicInfo.openingHours}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">推荐游玩时长</text>
      <text class="info-value">{{scenicInfo.suggestedDuration}}小时</text>
    </view>
  </view>

  <!-- 景点选择 -->
  <view class="attractions-section">
    <view class="section-title">
      <text>选择景点</text>
      <text class="selected-count">已选 {{selectedAttractions.length}} 个</text>
    </view>

    <scroll-view
      class="attractions-scroll"
      scroll-y="{{true}}"
    >
      <view
        wx:for="{{attractions}}"
        wx:key="id"
        class="attraction-item {{item.selected ? 'selected' : ''}}"
        bindtap="onAttractionTap"
        data-id="{{item.id}}"
      >
        <view class="attraction-icon">
          <icon
            type="{{item.selected ? 'success' : 'circle'}}"
            size="20"
            color="{{item.selected ? '#0F62FE' : '#ccc'}}"
          ></icon>
        </view>
        <view class="attraction-content">
          <view class="attraction-header">
            <text class="attraction-name">{{item.name}}</text>
            <text class="attraction-duration">{{item.duration}}分钟</text>
          </view>
          <text class="attraction-desc">{{item.description}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 选择终点 -->
  <view class="attractions-section">
    <view class="section-title">
      <text>选择终点</text>
    </view>
    
    <view class="end-point-options">
      <view
        class="end-point-item {{selectedEndPoint === 'current' ? 'selected' : ''}}"
        bindtap="onEndPointSelect"
        data-type="current"
      >
        <view class="end-point-icon">
          <icon
            type="{{selectedEndPoint === 'current' ? 'success' : 'circle'}}"
            size="20"
            color="{{selectedEndPoint === 'current' ? '#0F62FE' : '#ccc'}}"
          ></icon>
        </view>
        <view class="end-point-content">
          <text class="end-point-name">当前位置</text>
          <text class="end-point-desc">使用您的当前位置作为终点</text>
        </view>
      </view>
      
      <view
        class="end-point-item {{selectedEndPoint === 'exit' ? 'selected' : ''}}"
        bindtap="onEndPointSelect"
        data-type="exit"
      >
        <view class="end-point-icon">
          <icon
            type="{{selectedEndPoint === 'exit' ? 'success' : 'circle'}}"
            size="20"
            color="{{selectedEndPoint === 'exit' ? '#0F62FE' : '#ccc'}}"
          ></icon>
        </view>
        <view class="end-point-content">
          <text class="end-point-name">景区出口</text>
          <text class="end-point-desc">
            {{selectedEndPoint === 'exit' && endPoint ? '已选择: ' + endPoint.name : (showExitSelector ? '请选择具体出入口...' : '选择具体出入口作为终点')}}
          </text>
        </view>
      </view>
    </view>
    
    <!-- 出入口选择列表 -->
    <view class="exit-selector" wx:if="{{showExitSelector}}">
      <view class="exit-selector-header">
        <text class="exit-selector-title">选择出入口 ({{availableExits.length}}个)</text>
        <text class="exit-selector-cancel" bindtap="onCancelExitSelector">取消</text>
      </view>
      
      <!-- 空列表提示 -->
      <view class="exit-empty" wx:if="{{!availableExits || availableExits.length === 0}}">
        <text>未找到出入口，请稍后再试</text>
      </view>
      
      <!-- 出入口列表 -->
      <view class="exit-list-container" wx:if="{{availableExits && availableExits.length > 0}}">
        <scroll-view class="exit-list" scroll-y="{{true}}">
          <view
            wx:for="{{availableExits}}"
            wx:key="id"
            class="exit-item"
            bindtap="onSelectSpecificExit"
            data-index="{{index}}"
          >
            <view class="exit-icon">
              <icon type="location" size="16" color="#666"></icon>
            </view>
            <view class="exit-content">
              <text class="exit-name">{{item.name}}</text>
              <text class="exit-desc">{{item.description}}</text>
            </view>
            <view class="exit-check" wx:if="{{endPoint && endPoint.id === item.id}}">
              <icon type="success_no_circle" size="16" color="#0F62FE"></icon>
            </view>
          </view>
        </scroll-view>
      </view>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar">
    <button
      class="plan-button"
      disabled="{{selectedAttractions.length === 0}}"
      bindtap="onPlanRoute"
    >
      生成路线方案
    </button>
  </view>
</view>
