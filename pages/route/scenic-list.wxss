/* pages/route/scenic-list.wxss */
.scenic-list-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f6f6f6;
}

.search-bar {
  padding: 20rpx 30rpx;
  background-color: #fff;
}

.search-input-wrapper {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background-color: #f5f5f5;
  border-radius: 40rpx;
}

.search-input {
  flex: 1;
  margin-left: 12rpx;
  font-size: 28rpx;
}

.scenic-scroll {
  flex: 1;
  padding: 20rpx 30rpx;
}

.scenic-card {
  display: flex;
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.scenic-image {
  width: 240rpx;
  height: 200rpx;
  flex-shrink: 0;
}

.scenic-info {
  flex: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
}

.scenic-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.scenic-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-right: 12rpx;
}

.scenic-tag {
  padding: 4rpx 12rpx;
  background-color: #ff6b35;
  color: #fff;
  font-size: 20rpx;
  border-radius: 8rpx;
}

.scenic-desc {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.scenic-meta {
  display: flex;
  gap: 24rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #999;
}

.meta-item icon {
  margin-right: 6rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #999;
}
