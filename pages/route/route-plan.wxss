/* pages/route/route-plan.wxss */
.route-plan-container {
  min-height: 100vh;
  background-color: #f6f6f6;
  padding-bottom: 20rpx;
}

.route-type-section {
  margin: 20rpx 30rpx;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.type-tabs {
  display: flex;
  gap: 20rpx;
}

.type-tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.3s;
}

.type-tab.active {
  background-color: #0F62FE;
  color: #fff;
}

.route-schemes {
  margin: 0 30rpx;
}

.schemes-scroll {
  height: calc(100vh - 300rpx);
}

.scheme-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.scheme-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.scheme-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.scheme-tag {
  padding: 6rpx 16rpx;
  background-color: #fff4e5;
  color: #ff6b35;
  font-size: 20rpx;
  border-radius: 8rpx;
}

.route-overview {
  display: flex;
  flex-direction: column;
  padding: 0 20rpx;
  margin-bottom: 24rpx;
}

.stop-item {
  display: flex;
  align-items: center;
  position: relative;
  padding: 16rpx 0;
}

.stop-icon {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: #0F62FE;
  flex-shrink: 0;
}

.stop-name {
  flex: 1;
  margin-left: 24rpx;
  font-size: 28rpx;
  color: #333;
}

.stop-line {
  position: absolute;
  left: 8rpx;
  top: 32rpx;
  width: 0;
  height: 60rpx;
  border-left: 2rpx dashed #e0e0e0;
}

.scheme-info {
  display: flex;
  gap: 40rpx;
  padding: 20rpx;
  background-color: #f9f9f9;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.info-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 24rpx;
  color: #666;
}

.scheme-action {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding-top: 10rpx;
}

.action-group {
  display: flex;
  gap: 40rpx;
}

.action-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 20rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  transition: all 0.3s;
}

.action-item:active {
  background-color: #e8e8e8;
}

.action-text {
  font-size: 26rpx;
  color: #0F62FE;
}
