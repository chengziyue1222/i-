page {
  background: #ededed;
  height: 100%;
}

.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background:
    radial-gradient(circle at top right, rgba(255,36,66,0.05), transparent 22%),
    linear-gradient(180deg, #fdfdfd 0%, #f4f4f4 25%, #ededed 100%);
}

.chat-header {
  padding: 20rpx 24rpx 16rpx;
  background: rgba(255,255,255,0.9);
  backdrop-filter: blur(8px);
  border-bottom: 1rpx solid rgba(0,0,0,0.04);
}

.chat-user {
  display: flex;
  align-items: center;
}

.chat-avatar {
  width: 84rpx;
  height: 84rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #07c160, #18d06f);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 28rpx rgba(7,193,96,0.16);
}

.chat-avatar-emoji {
  font-size: 34rpx;
}

.chat-user-info {
  margin-left: 18rpx;
}

.chat-user-name {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #111;
}

.chat-user-sub {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #999;
}

.chat-scroll {
  flex: 1;
  height: 0;
}

.chat-inner {
  padding: 22rpx 20rpx 10rpx;
}

.bottom-anchor {
  height: 2rpx;
}

.time-row {
  display: flex;
  justify-content: center;
  margin: 18rpx 0 24rpx;
}

.time-text {
  padding: 8rpx 18rpx;
  background: rgba(0,0,0,0.06);
  color: #777;
  font-size: 20rpx;
  border-radius: 999rpx;
}

.sys-row {
  display: flex;
  justify-content: center;
  margin: 18rpx 0 24rpx;
}

.sys-text {
  max-width: 560rpx;
  padding: 14rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(255,255,255,0.82);
  color: #888;
  font-size: 22rpx;
  text-align: center;
  line-height: 1.6;
  box-shadow: 0 4rpx 18rpx rgba(0,0,0,0.04);
}

.msg-row {
  display: flex;
  align-items: flex-end;
  margin-bottom: 24rpx;
}

.msg-row.other {
  justify-content: flex-start;
}

.msg-row.mine {
  justify-content: flex-end;
}

.msg-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.other-avatar {
  background: linear-gradient(135deg, #ffb199, #ff0844);
  box-shadow: 0 10rpx 24rpx rgba(255,36,66,0.14);
}

.mine-avatar {
  background: linear-gradient(135deg, #07c160, #18d06f);
  box-shadow: 0 10rpx 24rpx rgba(7,193,96,0.14);
}

.msg-avatar-emoji {
  font-size: 30rpx;
}

.msg-main {
  max-width: 70%;
  margin: 0 14rpx;
}

.mine-main {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.bubble {
  padding: 18rpx 22rpx;
  border-radius: 24rpx;
  word-break: break-word;
  position: relative;
}

.other-bubble {
  background: #ffffff;
  border-top-left-radius: 8rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.05);
}

.mine-bubble {
  background: linear-gradient(135deg, #07c160 0%, #18d06f 100%);
  border-top-right-radius: 8rpx;
  box-shadow: 0 8rpx 24rpx rgba(7,193,96,0.16);
}

.bubble-text {
  font-size: 29rpx;
  line-height: 1.65;
  color: #222;
}

.mine-text {
  color: #fff;
}

.msg-time {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #999;
  padding-left: 4rpx;
}

.mine-time {
  padding-left: 0;
  padding-right: 4rpx;
}

.quick-bar {
  width: 100%;
  background: rgba(255,255,255,0.95);
  border-top: 1rpx solid rgba(0,0,0,0.04);
  white-space: nowrap;
}

.quick-list {
  display: inline-flex;
  padding: 16rpx 18rpx 8rpx;
}

.quick-item {
  margin-right: 12rpx;
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: #fff3f5;
  color: #ff2442;
  font-size: 22rpx;
  border: 1rpx solid rgba(255,36,66,0.12);
  flex-shrink: 0;
}

.input-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 18rpx calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(255,255,255,0.96);
  border-top: 1rpx solid rgba(0,0,0,0.04);
}

.input-wrap {
  flex: 1;
  min-height: 76rpx;
  border-radius: 24rpx;
  background: #f7f7f7;
  padding: 0 22rpx;
  display: flex;
  align-items: center;
}

.chat-input {
  width: 100%;
  height: 76rpx;
  font-size: 28rpx;
  color: #111;
}

.input-placeholder {
  color: #aaa;
}

.send-btn {
  margin-left: 14rpx;
  min-width: 112rpx;
  height: 76rpx;
  line-height: 76rpx;
  text-align: center;
  border-radius: 24rpx;
  background: #d9d9d9;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
}

.send-btn-active {
  background: linear-gradient(135deg, #07c160, #18d06f);
}
