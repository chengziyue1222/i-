<view class="chat-page">
  <view class="chat-head">
    <text class="chat-title">{{groupName}}</text>
    <text class="chat-sub">与 {{partnerName}} 沟通集合、路线与注意事项</text>
  </view>

  <scroll-view scroll-y class="chat-list" scroll-with-animation="{{true}}" scroll-into-view="msg-{{messages.length - 1}}">
    <view wx:for="{{messages}}" wx:key="id" class="msg-row {{item.sender === 'me' ? 'mine' : 'other'}}" id="msg-{{index}}">
      <view class="msg-bubble">
        <text class="msg-text">{{item.text}}</text>
      </view>
      <text class="msg-time">{{item.time}}</text>
    </view>
  </scroll-view>

  <view class="chat-input-wrap">
    <input
      class="chat-input"
      placeholder="输入消息..."
      value="{{inputValue}}"
      bindinput="onInput"
      confirm-type="send"
      bindconfirm="onSend"
      cursor-spacing="24"
    />
    <view class="send-btn" bindtap="onSend">发送</view>
  </view>
</view>
