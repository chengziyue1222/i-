<view class="page">
  <view class="chat-header">
    <view class="chat-user">
      <view class="chat-avatar">
        <text class="chat-avatar-emoji">{{targetEmoji}}</text>
      </view>
      <view class="chat-user-info">
        <text class="chat-user-name">{{targetName}}</text>
        <text class="chat-user-sub">在线 · 可发消息</text>
      </view>
    </view>
  </view>

  <scroll-view
    scroll-y
    class="chat-scroll"
    scroll-into-view="{{scrollAnchor}}"
    enhanced="{{true}}"
    show-scrollbar="{{false}}"
  >
    <view class="chat-inner">
      <block wx:for="{{messageGroups}}" wx:key="id">
        <view wx:if="{{item._type === 'time'}}" class="time-row">
          <text class="time-text">{{item.label}}</text>
        </view>

        <view wx:if="{{item._type === 'message' && item.type === 'system'}}" class="sys-row">
          <text class="sys-text">{{item.content}}</text>
        </view>

        <view wx:if="{{item._type === 'message' && item.type !== 'system'}}">
          <view wx:if="{{!item.isMine}}" class="msg-row other">
            <view class="msg-avatar other-avatar">
              <text class="msg-avatar-emoji">{{targetEmoji}}</text>
            </view>
            <view class="msg-main">
              <view class="bubble other-bubble">
                <text class="bubble-text">{{item.content}}</text>
              </view>
              <text class="msg-time">{{item.timeText}}</text>
            </view>
          </view>

          <view wx:if="{{item.isMine}}" class="msg-row mine">
            <view class="msg-main mine-main">
              <view class="bubble mine-bubble">
                <text class="bubble-text mine-text">{{item.content}}</text>
              </view>
              <text class="msg-time mine-time">{{item.timeText}}</text>
            </view>
            <view class="msg-avatar mine-avatar">
              <text class="msg-avatar-emoji">🙋</text>
            </view>
          </view>
        </view>
      </block>

      <view id="bottom-anchor" class="bottom-anchor"></view>
    </view>
  </scroll-view>

  <scroll-view scroll-x class="quick-bar" show-scrollbar="{{false}}">
    <view class="quick-list">
      <view class="quick-item" bindtap="onQuickReply" data-text="好的，我们约一下时间">
        好的，我们约一下时间
      </view>
      <view class="quick-item" bindtap="onQuickReply" data-text="你方便几点出发？">
        你方便几点出发？
      </view>
      <view class="quick-item" bindtap="onQuickReply" data-text="我们到时候地铁口见">
        我们到时候地铁口见
      </view>
    </view>
  </scroll-view>

  <view class="input-bar">
    <view class="input-wrap">
      <input
        class="chat-input"
        value="{{inputValue}}"
        bindinput="onInput"
        placeholder="发消息..."
        placeholder-class="input-placeholder"
        confirm-type="send"
        bindconfirm="onSend"
        cursor-spacing="20"
      />
    </view>
    <view class="send-btn {{inputValue ? 'send-btn-active' : ''}}" bindtap="onSend">
      发送
    </view>
  </view>
</view>
