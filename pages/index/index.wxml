<cloud-template-guide />
<!-- banner -->
<swiper wx:if="{{bannerList.length >0}}" class="poster" indicator-dots autoplay>
  <swiper-item wx:for="{{bannerList}}" wx:key="index">
    <image src="{{item}}"></image>
  </swiper-item>
</swiper>

<!-- 热门景区 -->
<view wx:if="{{hotScenicList.length > 0}}" class="common hot-scenic-section">
  <view class="common_title">
    <text>🔥 热门景区</text>
    <text class="hot-scenic-tip">热度排行</text>
  </view>
  <view class="hot-scenic-list">
    <view 
      wx:for="{{hotScenicList}}" 
      wx:key="scenicId" 
      class="hot-scenic-item"
      bindtap="goScenicDetail"
      data-id="{{item.scenicId}}"
      data-name="{{item.scenicName}}"
    >
      <view class="hot-scenic-rank">
        <text class="rank-number">{{index + 1}}</text>
      </view>
      <view class="hot-scenic-info">
        <view class="hot-scenic-name-container">
          <text class="hot-scenic-name">{{item.scenicName}}</text>
          <text class="hot-scenic-level">{{item.level}}</text>
        </view>
        <view class="hot-scenic-meta">
          <text class="hot-scenic-duration">建议游玩 {{item.suggestedDuration}} 小时</text>
          <view class="hot-scenic-heat">
            <text class="heat-icon">🔥</text>
            <text class="heat-score">{{item.heat}}°</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>

<!-- 最新攻略 -->
<view wx:if="{{newsList.length >0}}" class="common">
  <view class="common_title">
    <text>最新攻略</text>
    <view class="news_more" bind:tap="onGoNews">
      <text>更多</text>
      <image src="../../images/more.png"></image>
    </view>
  </view>
  <view class="news_list">
    <news-list wx:for="{{newsList}}" wx:key="index" title="{{item.title}}" time="{{item.time}}" image="{{item.picture}}" id="{{item._id}}" number="{{index}}"></news-list>
  </view>
</view>

<!-- 合作伙伴 -->
<view wx:if="{{partnersList.length >0}}" class="common">
  <view class="common_title">合作伙伴</view>
  <view class="partners_list">
    <view wx:for="{{partnersList}}" wx:key="index" class="partners_item">
      <image src="{{item.pic}}"></image>
    </view>
  </view>
</view>

<!-- 版本信息 -->
<version-info wx:if="{{partnersList.length >0}}"></version-info>
