.poster  swiper-item   image {
  height: 300rpx;
  width: 100%;
}

.template {
  margin: 20rpx;
  padding: 20rpx 0;
}

.template_list {
  display: flex;
  flex-wrap: wrap;
}
.template_item {
  width: 25%;
}

.template_item image {
  display: block;
  width: 72rpx;
  height: 72rpx;
  margin: 0 auto;
}

.template_item text {
  margin-top: 10rpx;
  width: 100%;
  display: block;
  font-size: 24rpx;
  line-height: 32rpx;
  color: #878D96;
  text-align: center;
}
.scene_list {
  overflow: hidden;
  flex-wrap: nowrap;
  white-space: nowrap;
}

.scene_item {
  display: inline-block;
  padding: 56rpx 0 0 24rpx;
  margin-left: 20rpx;
  width: 240rpx;
  height: 104rpx;
  background-repeat: no-repeat;
  background-position: center;
  background-size: 100% 100%;
  border-radius: 10rpx;
}

.scene_title {
  font-size: 32rpx;
  line-height: 48rpx;
  color: #0F62FE;
  font-weight: 400;
}

.scene_cont {
  font-size: 24rpx;
  line-height: 36rpx;
  color: #878D96;

}

.common {
  padding:24rpx 20rpx;
  margin: 20rpx;
  background-color: #fff;
  border-radius: 10rpx;
}

.common_title {
  padding: 20rpx;
  font-size: 32rpx;
  line-height: 48rpx;
  font-weight: 400;
}

.partners_list {
  display: flex;
  flex-wrap: wrap;
  padding: 0 20rpx 10rpx;
}

.partners_item {
  margin: 20rpx 10rpx 0 0;
  flex: 1 1 20rpx;
  height: 60rpx;
  padding: 20rpx 0;
  box-shadow: rgb(242, 244, 248) 0px 1px 10px 1px;

}

.partners_item image {
  width: 190rpx;
  height: 60rpx;
}

.news_more {
  float:right;
}
.news_more text {
  font-size: 24rpx;
  vertical-align: top;
  line-height: 36rpx;
  color: #878D96;
}
.news_more image {
  width: 32rpx;
  height: 32rpx;
  vertical-align: top;
}

/* 热门景区样式 */
.hot-scenic-section {
  margin: 20rpx;
  background-color: #fff;
  border-radius: 10rpx;
  padding: 24rpx 20rpx;
}

.hot-scenic-tip {
  float: right;
  font-size: 24rpx;
  color: #ff6b6b;
  background-color: #fff5f5;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.hot-scenic-list {
  padding: 10rpx 0;
}

.hot-scenic-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  margin-bottom: 16rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
  position: relative;
  overflow: hidden;
}

.hot-scenic-item:active {
  background-color: #edf2ff;
}

.hot-scenic-item:last-child {
  margin-bottom: 0;
}

/* 前三名特殊样式 */
.hot-scenic-item:nth-child(1) {
  background: linear-gradient(135deg, #fff9db 0%, #fff3bf 100%);
}

.hot-scenic-item:nth-child(2) {
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
}

.hot-scenic-item:nth-child(3) {
  background: linear-gradient(135deg, #fff4e6 0%, #ffe8cc 100%);
}

.hot-scenic-rank {
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.rank-number {
  font-size: 32rpx;
  font-weight: bold;
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  border-radius: 50%;
  color: #fff;
}

/* 前三名排名样式 */
.hot-scenic-item:nth-child(1) .rank-number {
  background-color: #ffd43b;
  color: #000;
}

.hot-scenic-item:nth-child(2) .rank-number {
  background-color: #adb5bd;
  color: #fff;
}

.hot-scenic-item:nth-child(3) .rank-number {
  background-color: #ffa94d;
  color: #fff;
}

.hot-scenic-item:nth-child(n+4) .rank-number {
  background-color: #e9ecef;
  color: #495057;
  font-size: 28rpx;
}

.hot-scenic-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.hot-scenic-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.hot-scenic-name-container {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.hot-scenic-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #212529;
  margin-right: 16rpx;
}

.hot-scenic-level {
  font-size: 24rpx;
  color: #339af0;
  background-color: #e7f5ff;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.hot-scenic-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.hot-scenic-duration {
  font-size: 24rpx;
  color: #868e96;
}

.hot-scenic-heat {
  display: flex;
  align-items: center;
}

.heat-icon {
  font-size: 28rpx;
  margin-right: 6rpx;
}

.heat-score {
  font-size: 28rpx;
  font-weight: 600;
  color: #ff6b6b;
}