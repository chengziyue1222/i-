/* 首页 - iTravel 样式 */

page {
  background: #f2f4f8;
  height: 100%;
}

.home-scroll {
  height: 100vh;
  box-sizing: border-box;
}

/* 顶部品牌区 */
.home-header {
  padding: 24rpx 32rpx 32rpx;
  background: #fff;
}

.brand {
  margin-bottom: 24rpx;
}

.brand-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #0f62fe;
  margin-bottom: 8rpx;
}

.brand-subtitle {
  font-size: 24rpx;
  color: #868e96;
}

.search-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #f5f5f5;
  border-radius: 40rpx;
}

.search-bar icon {
  margin-right: 16rpx;
}

.search-bar input {
  flex: 1;
  font-size: 28rpx;
  color: #495057;
}

/* 快捷入口 - 横向滚动 */
.shortcuts-scroll {
  padding: 24rpx 32rpx;
  background: #fff;
  margin-bottom: 16rpx;
}

.shortcuts {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 8rpx;
}

.shortcut-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  max-width: 20%;
}

.shortcut-item text {
  font-size: 24rpx;
  color: #495057;
  margin-top: 12rpx;
}

.shortcut-item.active text {
  color: #0f62fe;
  font-weight: 500;
}

.shortcut-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  background: #e9ecef;
}

.shortcut-item.active .shortcut-icon {
  background: #e7f5ff;
}

/* 通用区块 */
.section {
  margin: 0 24rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #212529;
}

.section-more {
  font-size: 26rpx;
  color: #0f62fe;
}

/* 热门景点推荐 - 大卡片 */
.hot-attraction-section .featured-card {
  position: relative;
  height: 320rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.featured-bg {
  width: 100%;
  height: 100%;
}

.featured-overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 32rpx 24rpx 24rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.6));
  color: #fff;
}

.featured-name {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.featured-desc {
  display: block;
  font-size: 24rpx;
  opacity: 0.9;
  margin-bottom: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.featured-tags {
  display: flex;
  gap: 16rpx;
}

.tag-pill {
  padding: 8rpx 20rpx;
  background: rgba(255,255,255,0.9);
  color: #495057;
  font-size: 22rpx;
  border-radius: 24rpx;
}

/* 当季必去 - 路线卡片 */
.filter-pills {
  display: flex;
  gap: 16rpx;
}

.filter-pill {
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  color: #868e96;
  background: #f1f3f5;
  border-radius: 24rpx;
}

.filter-pill.active {
  background: #e7f5ff;
  color: #0f62fe;
  font-weight: 500;
}

.route-cards {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.route-card {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.route-card:active {
  background: #edf2ff;
}

.route-card-img {
  width: 160rpx;
  height: 120rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.route-card-info {
  flex: 1;
  margin-left: 24rpx;
}

.route-card-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #212529;
  margin-bottom: 8rpx;
}

.route-card-meta {
  font-size: 24rpx;
  color: #868e96;
}

/* 搭子帖子广场 */
.post-cards {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.post-card {
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.post-card:active {
  background: #edf2ff;
}

.post-card-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.post-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.post-nickname {
  font-size: 28rpx;
  font-weight: 600;
  color: #212529;
}

.post-card-body {
  padding-left: 80rpx;
}

.post-destination {
  margin-bottom: 12rpx;
}

.post-destination .label {
  font-size: 22rpx;
  color: #868e96;
  margin-right: 8rpx;
}

.post-destination .value {
  font-size: 28rpx;
  color: #212529;
  font-weight: 500;
}

.post-meta {
  display: flex;
  gap: 24rpx;
  margin-bottom: 12rpx;
}

.meta-item {
  font-size: 24rpx;
  color: #868e96;
}

.post-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.post-tag {
  padding: 6rpx 16rpx;
  background: #e7f5ff;
  color: #339af0;
  font-size: 22rpx;
  border-radius: 20rpx;
}

.empty-posts {
  padding: 48rpx 0;
  text-align: center;
  font-size: 28rpx;
  color: #868e96;
}

/* 最新攻略 */
.news-section .section-header {
  margin-bottom: 16rpx;
}

.news_list {
  padding: 0;
}

.news_list .news_item {
  padding: 20rpx 0;
}

.news_list .news_item_border {
  border-top: 1rpx solid #f1f3f5;
}

.news_more {
  float: right;
}

.news_more text {
  font-size: 24rpx;
  vertical-align: top;
  line-height: 36rpx;
  color: #868e96;
}

.news_more image {
  width: 32rpx;
  height: 32rpx;
  vertical-align: top;
}
