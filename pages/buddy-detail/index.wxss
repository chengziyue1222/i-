.page { min-height:100vh; background:#f2f3f7; padding-bottom:160rpx; }

.hero { height:380rpx; position:relative; display:flex; align-items:flex-end; overflow:hidden; }
.hero-emoji { position:absolute; top:50%; left:50%; transform:translate(-50%,-60%); font-size:100rpx; }
.hero-overlay { position:absolute; inset:0; background:linear-gradient(to bottom, rgba(0,0,0,.1) 0%, rgba(0,0,0,.55) 100%); }
.hero-info { position:relative; z-index:1; padding:0 32rpx 32rpx; width:100%; box-sizing:border-box; }
.hero-dest { display:block; color:#fff; font-size:44rpx; font-weight:800; margin-bottom:12rpx; }
.hero-status { display:inline-block; font-size:24rpx; font-weight:600; padding:8rpx 20rpx; border-radius:20rpx; }
.hero-status-recruiting { background:rgba(43,138,62,.9); color:#fff; }
.hero-status-full { background:rgba(201,42,42,.85); color:#fff; }

.scroll { height:calc(100vh - 380rpx - 160rpx); }

.section { margin:20rpx 24rpx 0; }
.section-title { display:block; font-size:24rpx; font-weight:700; color:#999; letter-spacing:1px; margin-bottom:12rpx; }

.creator-row { background:#fff; border-radius:20rpx; padding:24rpx 28rpx; display:flex; align-items:center; gap:20rpx; box-shadow:0 4rpx 16rpx rgba(0,0,0,.05); }
.c-avatar { width:88rpx; height:88rpx; border-radius:50%; background:linear-gradient(135deg,#0f62fe,#228be6); color:#fff; font-size:40rpx; font-weight:700; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.c-info { flex:1; }
.c-name-row { display:flex; align-items:center; gap:12rpx; margin-bottom:8rpx; }
.c-name { font-size:30rpx; font-weight:700; color:#1a1a1a; }
.c-mbti { font-size:20rpx; color:#fff; background:linear-gradient(135deg,#ffd43b,#ff922b); padding:4rpx 12rpx; border-radius:10rpx; font-weight:700; }
.c-role { font-size:24rpx; color:#999; }
.share-btn { font-size:24rpx; color:#0f62fe; background:#e7f0ff; padding:10rpx 24rpx; border-radius:20rpx; flex-shrink:0; }

.info-card { background:#fff; border-radius:20rpx; padding:24rpx 28rpx; box-shadow:0 4rpx 16rpx rgba(0,0,0,.05); display:flex; flex-direction:column; gap:16rpx; }
.info-row { display:flex; align-items:center; gap:12rpx; }
.i-label { font-size:26rpx; color:#999; width:160rpx; flex-shrink:0; }
.i-val { font-size:28rpx; color:#333; flex:1; }
.dest { font-weight:700; color:#1a1a1a; font-size:30rpx; }
.pbar { flex:1; height:8rpx; background:#eee; border-radius:4rpx; overflow:hidden; }
.pbar-fill { height:100%; background:linear-gradient(90deg,#0f62fe,#228be6); border-radius:4rpx; }

.tags-wrap { background:#fff; border-radius:20rpx; padding:24rpx 28rpx; box-shadow:0 4rpx 16rpx rgba(0,0,0,.05); display:flex; flex-wrap:wrap; gap:12rpx; }
.tag { font-size:24rpx; color:#0f62fe; background:#e7f0ff; padding:10rpx 20rpx; border-radius:16rpx; font-weight:500; }
.tag-empty { font-size:26rpx; color:#bbb; }

.reasons-wrap { background:#fffbec; border-radius:20rpx; padding:24rpx 28rpx; box-shadow:0 4rpx 16rpx rgba(0,0,0,.04); display:flex; flex-wrap:wrap; gap:12rpx; border:1rpx solid rgba(255,212,59,.3); }
.reason { font-size:24rpx; color:#d9770f; background:rgba(255,212,59,.15); padding:8rpx 16rpx; border-radius:12rpx; }

.intro-box { background:#fff; border-radius:20rpx; padding:28rpx; box-shadow:0 4rpx 16rpx rgba(0,0,0,.05); font-size:28rpx; color:#444; line-height:1.8; }

.footer { position:fixed; bottom:0; left:0; right:0; padding:20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom)); background:#fff; border-top:1rpx solid #eee; }
.btn-apply { background:linear-gradient(135deg,#0f62fe,#228be6); color:#fff; text-align:center; padding:28rpx; border-radius:16rpx; font-size:32rpx; font-weight:700; box-shadow:0 6rpx 20rpx rgba(15,98,254,.35); }
.btn-apply:active { opacity:.85; }
.btn-disabled { background:#dee2e6 !important; color:#aaa !important; box-shadow:none !important; }
