page {
  background: #f7f3ee;
}

.community-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background:
    radial-gradient(circle at top, rgba(255, 240, 221, 0.8), transparent 30%),
    linear-gradient(180deg, #faf7f1 0%, #f5efe7 100%);
}

.hero-panel {
  margin: 24rpx 24rpx 18rpx;
  padding: 30rpx 28rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #1e1f2f 0%, #4b2f24 52%, #8f4d2e 100%);
  box-shadow: 0 22rpx 40rpx rgba(76, 42, 28, 0.22);
}
.hero-copy { flex: 1; min-width: 0; }
.hero-kicker { display:block; font-size: 20rpx; letter-spacing: 4rpx; color: rgba(255, 226, 194, 0.8); }
.hero-title { display:block; margin-top: 12rpx; font-size: 40rpx; line-height: 1.35; color:#fff8ef; font-weight: 800; }
.hero-desc { display:block; margin-top: 14rpx; font-size: 23rpx; color: rgba(255, 239, 219, 0.82); line-height: 1.6; }
.hero-orb {
  width: 96rpx;
  height: 96rpx;
  margin-left: 20rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 30% 30%, #ffd9a5, #ff8f5c 70%);
  color: #44200f;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42rpx;
  font-weight: 700;
  box-shadow: 0 10rpx 24rpx rgba(255, 166, 94, 0.35);
}

.tab-scroll { margin-top: 8rpx; }
.tab-row { display:flex; gap: 14rpx; padding: 0 24rpx 12rpx; white-space: nowrap; }
.tab-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0 28rpx;
  height: 68rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.75);
  color: #7b6257;
  font-size: 26rpx;
  font-weight: 600;
  border: 1rpx solid rgba(126, 88, 69, 0.08);
}
.tab-pill-active {
  background: linear-gradient(135deg, #ff7f50, #ff5f6d);
  color: #fff;
  box-shadow: 0 12rpx 20rpx rgba(255, 95, 109, 0.22);
}

.feed-scroll { flex: 1; min-height: 0; }
.waterfall { display:flex; align-items:flex-start; gap: 16rpx; padding: 14rpx 18rpx 140rpx; }
.waterfall-col { flex:1; min-width:0; }
.post-card {
  margin-bottom: 16rpx;
  border-radius: 28rpx;
  overflow: hidden;
  background: rgba(255,255,255,0.96);
  box-shadow: 0 18rpx 32rpx rgba(104, 76, 56, 0.1);
}
.post-cover {
  width: 100%;
  height: 320rpx;
  display: block;
}
.post-body { padding: 22rpx 22rpx 24rpx; }
.post-title { display:block; font-size: 30rpx; color:#2a1d18; font-weight: 800; line-height: 1.5; }
.post-desc { display:block; margin-top: 10rpx; font-size: 24rpx; color:#7c665b; line-height: 1.7; }
.post-footer { margin-top: 18rpx; display:flex; align-items:center; justify-content:space-between; }
.post-author { display:flex; align-items:center; gap: 10rpx; min-width:0; }
.author-avatar { width: 44rpx; height: 44rpx; border-radius: 50%; background:#f2dfd1; }
.author-name { font-size: 22rpx; color:#5f4a41; max-width: 160rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.post-like {
  min-width: 100rpx;
  height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #f8efe8;
  color:#9b7060;
  display:flex;
  align-items:center;
  justify-content:center;
  font-size: 22rpx;
  font-weight: 700;
  transition: all .18s ease;
}
.post-like-active {
  background: #fff0f2;
  color: #e8505b;
  transform: scale(1.04);
}

.loading-state { display:flex; flex-wrap:wrap; gap: 16rpx; padding: 14rpx 18rpx 0; }
.loading-card {
  width: calc(50% - 8rpx);
  height: 420rpx;
  border-radius: 28rpx;
  background: linear-gradient(90deg, rgba(255,255,255,.8), rgba(245,236,227,.95), rgba(255,255,255,.8));
  background-size: 200% 100%;
  animation: shimmer 1.4s infinite linear;
}
@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

.empty-state {
  padding: 180rpx 40rpx 0;
  text-align: center;
  color: #8c7568;
}
.empty-icon { display:block; font-size: 76rpx; }
.empty-title { display:block; margin-top: 18rpx; font-size: 30rpx; color:#513b33; font-weight:700; }
.empty-desc { display:block; margin-top: 12rpx; font-size: 24rpx; line-height: 1.7; }
.feed-bottom-space { height: 160rpx; }

.publish-fab {
  position: fixed;
  right: 30rpx;
  bottom: 110rpx;
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1f2231, #ff7a59);
  box-shadow: 0 18rpx 30rpx rgba(67, 38, 27, 0.24);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 30;
}
.publish-fab:active { transform: scale(0.95); }
.publish-fab-icon { color:#fff; font-size: 58rpx; line-height: 1; }
