<view class="profile-page">
  <view class="custom-nav-bar">
    <view class="nav-title">我的</view>
  </view>

  <scroll-view scroll-y class="profile-scroll">
    <view class="user-card-container">
      <image class="bg-image" src="{{userInfo.bgImage}}" mode="aspectFill" wx:if="{{userInfo.bgImage}}"></image>
      <view class="bg-overlay"></view>

      <view class="bg-upload-btn" wx:if="{{isLoggedIn}}" bindtap="onUploadBgImage">
        <text class="bg-upload-icon">📷</text>
        <text class="bg-upload-text">背景</text>
      </view>

      <view class="user-card-content">
        <block wx:if="{{isLoggedIn}}">
          <view class="hero-centerline">
            <view class="user-avatar-wrap">
              <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
                <image class="user-avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
              </button>
            </view>

            <view class="user-info-main">
              <view class="user-nickname-row" bindtap="onNicknameTap">
                <text class="user-nickname">{{userInfo.nickName}}</text>
                <text class="mbti-badge">✨ ENFP</text>
                <text class="edit-icon">✎</text>
              </view>
              <text class="user-manifesto">{{userInfo.manifesto}}</text>
            </view>
          </view>

          <view class="user-tags-section">
            <view class="user-tags">
              <view wx:for="{{styledTags}}" wx:key="text" class="tag" style="{{item.style}}">
                {{item.text}}
              </view>
              <view class="tag-add-btn" bindtap="onTagsTap">
                <text class="tag-add-icon">+</text>
              </view>
            </view>
          </view>
        </block>

        <block wx:else>
          <view class="login-prompt">
            <text class="login-title">登录 i旅图</text>
            <text class="login-desc">微信授权登录后，可管理自己的内容与旅行偏好</text>
            <button class="btn-wechat-login" bindtap="onWechatLogin">微信授权登录</button>
          </view>
        </block>
      </view>
    </view>

    <view class="modal-mask" wx:if="{{showNicknameEdit}}" bindtap="onNicknameCancel">
      <view class="modal-box" catchtap="">
        <view class="modal-title">修改昵称</view>
        <input class="modal-input" placeholder="请输入昵称" value="{{editNickname}}" bindinput="onNicknameInput" focus="{{showNicknameEdit}}" />
        <view class="modal-actions">
          <view class="modal-btn" bindtap="onNicknameCancel">取消</view>
          <view class="modal-btn primary" bindtap="onNicknameConfirm">确定</view>
        </view>
      </view>
    </view>

    <view class="stats-bar">
      <view class="stat-item">
        <view class="stat-icon">📍</view>
        <text class="stat-value">{{stats.checkinCount}}</text>
        <text class="stat-label">已打卡景点</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <view class="stat-icon">📅</view>
        <text class="stat-value">{{stats.travelDays}}</text>
        <text class="stat-label">行程天数</text>
      </view>
    </view>

    <view class="section">

      <view class="section-head">
        <text>我的发布</text>
        <text>{{myPosts.length}} 篇</text>
      </view>

      <block wx:if="{{myPosts.length}}">
        <block wx:for="{{myPosts}}" wx:key="id">

          <view class="post-card" bindtap="onMyPostTap" data-id="{{item.id}}">

            <image class="cover" src="{{item.cover || '/images/scenic/qixingyan.jpg'}}" mode="aspectFill"></image>

            <view class="content">
              <text class="title">{{item.title}}</text>

              <text class="tag">
                {{item.visibility === 'private' ? '🔒 仅自己可见' : '🌍 公开'}}
              </text>

              <text class="meta">
                ❤️ {{item.likeCount}} 💬 {{item.commentCount}}
              </text>
            </view>

            <view class="more"
              catchtap="onMyPostMore"
              data-post="{{item}}">
              ⋯
            </view>

          </view>

        </block>
      </block>

      <view wx:else class="empty">
        还没有发布内容
      </view>

    </view>

    <view class="likes-panel">
      <view class="likes-panel-head">
        <view>
          <text class="likes-panel-title">我的点赞</text>
          <text class="likes-panel-subtitle">收藏过的旅行灵感都会留在这里</text>
        </view>
        <text class="likes-panel-count">{{likedPosts.length}} 篇</text>
      </view>

      <view wx:if="{{likedPosts.length}}" class="likes-grid">
        <view wx:for="{{likedPosts}}" wx:key="id" class="liked-card" bindtap="onLikePostTap" data-id="{{item.id}}">
          <image class="liked-cover" src="{{item.cover || '/images/scenic/qixingyan.jpg'}}" mode="aspectFill" lazy-load="true"></image>
          <view class="liked-body">
            <text class="liked-title">{{item.title}}</text>
            <view class="liked-meta">
              <text class="liked-author">{{item.author.name}}</text>
              <text class="liked-heart">❤ {{item.likeCount}}</text>
            </view>
          </view>
        </view>
      </view>

      <view wx:else class="likes-empty">
        <text class="likes-empty-icon">♡</text>
        <text class="likes-empty-title">还没有点赞的内容</text>
        <text class="likes-empty-desc">去社区逛逛，把喜欢的景点、美食和路线收藏下来。</text>
      </view>
    </view>

    <view class="func-list">
      <view class="func-item" bindtap="onMyTrips">
        <view class="func-left">
          <view class="func-icon" style="background: linear-gradient(135deg, #e7f5ff 0%, #d0ebff 100%);">
            <text class="func-icon-text">📋</text>
          </view>
          <view class="func-text">
            <text class="func-title">我的行程库</text>
            <text class="func-desc">查看和管理旅行计划</text>
          </view>
        </view>
        <text class="func-arrow">›</text>
      </view>

      <view class="func-item" bindtap="onSafetyCenter">
        <view class="func-left">
          <view class="func-icon" style="background: linear-gradient(135deg, #fff3bf 0%, #ffe066 100%);">
            <text class="func-icon-text">🛡</text>
          </view>
          <view class="func-text">
            <text class="func-title">安全中心</text>
            <text class="func-desc">紧急联系人、位置分享</text>
          </view>
        </view>
        <text class="func-arrow">›</text>
      </view>

      <view class="func-item" bindtap="onSettings">
        <view class="func-left">
          <view class="func-icon" style="background: linear-gradient(135deg, #f1f3f5 0%, #e9ecef 100%);">
            <text class="func-icon-text">⚙</text>
          </view>
          <view class="func-text">
            <text class="func-title">设置</text>
            <text class="func-desc">账号与隐私</text>
          </view>
        </view>
        <text class="func-arrow">›</text>
      </view>
    </view>

    <view class="bottom-area">
      <version-info></version-info>
      <view class="customer-entry" bindtap="onCustomerService">
        <text>客服与反馈</text>
        <text class="entry-arrow">›</text>
      </view>
      <view class="footer-slogan">i旅图 - 懂旅行，更懂你</view>
    </view>
  </scroll-view>
</view>
