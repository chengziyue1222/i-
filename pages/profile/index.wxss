.profile-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #edf3fb 0%, #f7f9fd 100%);
  padding-bottom: env(safe-area-inset-bottom);
}

.profile-scroll {
  height: 100vh;
}

.custom-nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 88rpx;
  padding-top: env(safe-area-inset-top);
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  z-index: 50;
}

.nav-title {
  color: #fff;
  font-weight: 700;
  font-size: 32rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.user-card-container {
  position: relative;
  margin-top: calc(88rpx + env(safe-area-inset-top));
  min-height: 620rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  justify-content: flex-end;
  background:
    radial-gradient(circle at 20% 18%, rgba(120, 201, 255, 0.2), rgba(120, 201, 255, 0) 26%),
    radial-gradient(circle at 82% 16%, rgba(255, 210, 124, 0.16), rgba(255, 210, 124, 0) 24%),
    linear-gradient(160deg, #091a38 0%, #0f3460 42%, #151b35 100%);
}

.bg-image {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  filter: blur(4px);
}

.bg-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(9, 16, 33, 0.22) 0%, rgba(9, 16, 33, 0.56) 100%);
  z-index: 1;
}

.bg-upload-btn {
  position: absolute;
  right: 28rpx;
  bottom: 30rpx;
  width: 78rpx;
  height: 78rpx;
  padding: 0;
  background: rgba(255, 255, 255, 0.18);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
  z-index: 10;
  backdrop-filter: blur(14px);
  border: 1rpx solid rgba(255, 255, 255, 0.24);
  box-shadow: 0 10rpx 24rpx rgba(0, 0, 0, 0.22);
}

.bg-upload-icon {
  font-size: 30rpx;
  line-height: 1;
}

.bg-upload-text {
  display: none;
}

.user-card-content {
  position: relative;
  z-index: 2;
  width: 100%;
  padding: 92rpx 32rpx 128rpx;
  color: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.hero-centerline {
  width: auto;
  max-width: 620rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx 28rpx 12rpx;
  border-radius: 30rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0.08));
  box-shadow: 0 18rpx 38rpx rgba(0, 0, 0, 0.12);
  backdrop-filter: blur(8px);
}

.avatar-btn {
  padding: 0;
  margin: 0;
  background: none;
  border: none;
  line-height: 1;
}

.avatar-btn::after {
  border: none;
}

.user-avatar-wrap {
  margin-bottom: 6rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  width: 100%;
  transform: translateX(70rpx);
}

.user-avatar {
  width: 164rpx;
  height: 164rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.95);
  display: block;
  box-shadow: 0 18rpx 36rpx rgba(0, 0, 0, 0.28);
}

.user-info-main {
  margin-bottom: 10rpx;
  margin-top: 16rpx;
  text-align: center;
  width: auto;
  max-width: 620rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.user-nickname-row {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  margin-bottom: 10rpx;
  gap: 10rpx;
}

.user-nickname {
  font-size: 44rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
  text-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.18);
}

.mbti-badge {
  font-size: 20rpx;
  background: rgba(255, 255, 255, 0.18);
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  backdrop-filter: blur(12px);
  border: 1rpx solid rgba(255, 255, 255, 0.22);
}

.edit-icon {
  font-size: 24rpx;
  opacity: 0.82;
}

.user-manifesto {
  display: block;
  font-size: 25rpx;
  opacity: 0.96;
  line-height: 1.62;
  font-weight: 400;
}

.user-tags-section {
  width: auto;
  max-width: 620rpx;
  margin-top: 4rpx;
}

.user-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  justify-content: center;
  max-width: 620rpx;
}

.tag {
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 18rpx rgba(0, 0, 0, 0.14);
}

.tag-add-btn {
  width: 50rpx;
  height: 50rpx;
  border-radius: 25rpx;
  background: rgba(255, 255, 255, 0.28);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #fff;
  border: 2rpx dashed rgba(255, 255, 255, 0.42);
}

.tag-add-icon {
  font-weight: 600;
}

.login-prompt {
  padding: 32rpx 0;
  text-align: center;
}

.login-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.login-desc {
  display: block;
  font-size: 26rpx;
  opacity: 0.95;
  margin-bottom: 32rpx;
}

.btn-wechat-login {
  display: inline-block;
  padding: 24rpx 64rpx;
  background: #fff;
  color: #0f62fe;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
}

.btn-wechat-login::after {
  border: none;
}

.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-box {
  width: 600rpx;
  background: #fff;
  border-radius: 18rpx;
  padding: 32rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #212529;
  margin-bottom: 24rpx;
}

.modal-input {
  width: 100%;
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  font-size: 28rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
}

.modal-actions {
  display: flex;
  justify-content: flex-end;
  gap: 24rpx;
}

.modal-btn {
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  color: #495057;
}

.modal-btn.primary {
  color: #0f62fe;
  font-weight: 600;
}

.stats-bar {
  display: flex;
  align-items: stretch;
  justify-content: space-around;
  background: rgba(255, 255, 255, 0.97);
  margin: 24rpx;
  padding: 28rpx 16rpx;
  border-radius: 24rpx;
  box-shadow: 0 14rpx 32rpx rgba(27, 51, 91, 0.08);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.stat-icon {
  font-size: 30rpx;
  margin-bottom: 8rpx;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 8rpx;
  font-family: 'DIN Alternate', 'Montserrat', monospace;
  letter-spacing: 1px;
}

.stat-label {
  font-size: 26rpx;
  color: #868e96;
  font-weight: 500;
}

.stat-divider {
  width: 1rpx;
  height: 86rpx;
  background: linear-gradient(180deg, rgba(233, 236, 239, 0), rgba(233, 236, 239, 1), rgba(233, 236, 239, 0));
}

.section,
.likes-panel,
.func-list {
  margin: 0 24rpx 24rpx;
  background: rgba(255, 255, 255, 0.97);
  border-radius: 24rpx;
  box-shadow: 0 14rpx 32rpx rgba(27, 51, 91, 0.08);
}

.section,
.likes-panel {
  padding: 28rpx;
}

.section-head,
.likes-panel-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-head text:first-child,
.likes-panel-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #1a2233;
}

.section-head text:last-child,
.likes-panel-count {
  font-size: 24rpx;
  color: #245cc2;
  background: #eef4ff;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-weight: 600;
}

.likes-panel-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8a94a6;
}

.post-card,
.liked-card {
  background: linear-gradient(180deg, #ffffff 0%, #fafcff 100%);
  border-radius: 18rpx;
  box-shadow: inset 0 0 0 1rpx rgba(236, 240, 247, 0.8);
}

.post-card {
  display: flex;
  padding: 20rpx;
  margin-bottom: 18rpx;
  position: relative;
}

.cover {
  width: 140rpx;
  height: 140rpx;
  border-radius: 14rpx;
}

.content {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.title {
  font-size: 28rpx;
  font-weight: 700;
  color: #202939;
  line-height: 1.45;
}

.tag,
.meta {
  display: inline-flex;
  align-items: center;
  margin-top: 10rpx;
  color: #7c8699;
  font-size: 23rpx;
}

.more {
  position: absolute;
  right: 18rpx;
  top: 16rpx;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #f4f7fb;
  color: #8b95a7;
}

.empty,
.likes-empty {
  min-height: 156rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #99a1b3;
  text-align: center;
}

.likes-empty-icon {
  font-size: 42rpx;
  margin-bottom: 8rpx;
}

.likes-empty-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #6f7a8e;
}

.likes-empty-desc,
.empty {
  font-size: 25rpx;
  line-height: 1.7;
}

.likes-grid {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.liked-card {
  display: flex;
  align-items: stretch;
  overflow: hidden;
}

.liked-cover {
  width: 180rpx;
  height: 140rpx;
  flex-shrink: 0;
}

.liked-body {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.liked-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #202939;
  line-height: 1.45;
}

.liked-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
  font-size: 23rpx;
  color: #8a94a6;
}

.func-list {
  padding: 14rpx 0;
  overflow: hidden;
}

.func-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
}

.func-item + .func-item {
  border-top: 1rpx solid #edf1f7;
}

.func-left {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.func-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.func-icon-text {
  font-size: 34rpx;
}

.func-text {
  display: flex;
  flex-direction: column;
}

.func-title {
  font-size: 29rpx;
  font-weight: 700;
  color: #202939;
}

.func-desc {
  margin-top: 6rpx;
  font-size: 23rpx;
  color: #8a94a6;
}

.func-arrow,
.entry-arrow {
  color: #b0b8c7;
  font-size: 34rpx;
}

.bottom-area {
  padding: 12rpx 24rpx 44rpx;
}

.customer-entry {
  margin-top: 16rpx;
  background: rgba(255, 255, 255, 0.96);
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #202939;
  box-shadow: 0 12rpx 28rpx rgba(27, 51, 91, 0.08);
}

.footer-slogan {
  text-align: center;
  margin-top: 24rpx;
  color: #9aa4b5;
  font-size: 22rpx;
  letter-spacing: 2rpx;
}
