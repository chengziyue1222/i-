.profile-page {
  min-height: 100vh;
  background: #f2f4f8;
  padding-bottom: env(safe-area-inset-bottom);
}

/* 沉浸式导航栏 */
.custom-nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 88rpx;
  padding-top: env(safe-area-inset-top);
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  z-index: 50;
  color: #fff;
  font-weight: 600;
  font-size: 32rpx;
}

.nav-title {
  color: #fff;
  font-weight: 600;
  font-size: 32rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

/* 1. 用户信息卡片 (30%) */
.user-card-container {
  position:relative;
  margin-top:calc(88rpx + env(safe-area-inset-top));
  height:560rpx; overflow:hidden;
  display:flex; flex-direction:column;
  align-items:center; justify-content:flex-end;
  background:linear-gradient(160deg,#0f3460 0%,#1a1a2e 60%,#16213e 100%);
}

.bg-image {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  filter: blur(4px);
}

.bg-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.3) 0%, rgba(0, 0, 0, 0.5) 100%);
  z-index: 1;
}

.bg-upload-btn {
  position: absolute;
  bottom: 24rpx;
  right: 24rpx;
  width: 72rpx;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  z-index: 10;
  backdrop-filter: blur(10px);
}

.user-card-content {
  position: relative;
  z-index: 2;
  width: 100%;
  padding: 56rpx 32rpx 48rpx;
  color: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.avatar-btn {
  padding: 0;
  margin: 0;
  background: none;
  border: none;
  line-height: 1;
}

.avatar-btn::after {
  border: none;
}

.user-avatar-wrap {
  margin-bottom: 32rpx;
  display: flex;
  justify-content: center;
}

.user-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  display: block;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.2);
}

.user-info-main {
  margin-bottom: 28rpx;
  text-align: center;
  width: 100%;
}

.user-nickname-row {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  gap: 12rpx;
}

.user-nickname {
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: 0.5px;
}

.mbti-badge {
  font-size: 20rpx;
  background: rgba(255, 255, 255, 0.25);
  padding: 6rpx 12rpx;
  border-radius: 20rpx;
  backdrop-filter: blur(10px);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.edit-icon {
  font-size: 24rpx;
  opacity: 0.8;
  cursor: pointer;
}

.user-manifesto {
  display: block;
  font-size: 26rpx;
  opacity: 0.95;
  line-height: 1.6;
  font-weight: 300;
}

/* 彩色标签 */
.user-tags-section {
  width: 100%;
}

.user-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  justify-content: center;
}

.tag {
  padding: 12rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 500;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  transition: transform 0.2s ease;
}

.tag:active {
  transform: scale(0.95);
}

/* 标签颜色映射 */
.tag-orange {
  background: #ffe066;
  color: #d9480f;
}

.tag-red {
  background: #ff8787;
  color: #c92a2a;
}

.tag-pink {
  background: #fcc2d7;
  color: #c2255c;
}

.tag-blue {
  background: #a5d8ff;
  color: #0c63e4;
}

.tag-purple {
  background: #d0bfff;
  color: #5f3dc4;
}

.tag-green {
  background: #b2f2bb;
  color: #2b8a3e;
}

.tag-brown {
  background: #d4a574;
  color: #5c2e1a;
}

.tag-cyan {
  background: #99e9f2;
  color: #0b7285;
}

.tag-yellow {
  background: #ffd43b;
  color: #b8860b;
}

/* 标签添加按钮 */
.tag-add-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #fff;
  border: 2rpx dashed rgba(255, 255, 255, 0.5);
  transition: all 0.2s ease;
}

.tag-add-btn:active {
  background: rgba(255, 255, 255, 0.5);
}

.tag-add-icon {
  font-weight: 600;
}

/* 未登录提示 */
.login-prompt {
  padding: 32rpx 0;
  text-align: center;
}

.login-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.login-desc {
  display: block;
  font-size: 26rpx;
  opacity: 0.95;
  margin-bottom: 32rpx;
}

.btn-wechat-login {
  display: inline-block;
  padding: 24rpx 64rpx;
  background: #fff;
  color: #0f62fe;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
}

.btn-wechat-login::after {
  border: none;
}

/* 昵称编辑弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-box {
  width: 600rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #212529;
  margin-bottom: 24rpx;
}

.modal-input {
  width: 100%;
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  font-size: 28rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
}

.modal-actions {
  display: flex;
  justify-content: flex-end;
  gap: 24rpx;
}

.modal-btn {
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  color: #495057;
}

.modal-btn.primary {
  color: #0f62fe;
  font-weight: 600;
}

/* 2. 数据统计栏 (10%) */
.stats-bar {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: #fff;
  margin: 24rpx;
  padding: 32rpx;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-icon {
  font-size: 32rpx;
  margin-bottom: 8rpx;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 8rpx;
  font-family: 'DIN Alternate', 'Montserrat', monospace;
  letter-spacing: 1px;
}

.stat-label {
  font-size: 26rpx;
  color: #868e96;
  font-weight: 500;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: #e9ecef;
}

/* 3. 功能列表 (50%) */
.func-list {
  margin: 0 24rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
}

.func-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f1f3f5;
  transition: background 0.15s ease;
}

.func-item:last-child {
  border-bottom: none;
}

.func-item:active {
  background: #f8f9fa;
}

.func-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.func-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.func-icon-text {
  font-size: 36rpx;
}

.func-text {
  display: flex;
  flex-direction: column;
}

.func-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #212529;
  margin-bottom: 6rpx;
}

.func-desc {
  font-size: 24rpx;
  color: #868e96;
}

.func-arrow {
  font-size: 40rpx;
  color: #ced4da;
  font-weight: 300;
  margin-left: 16rpx;
}

/* 4. 底部区域 (10%) */
.bottom-area {
  padding: 24rpx 32rpx 48rpx;
}

.customer-entry {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  margin-top: 24rpx;
  background: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #495057;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  transition: background 0.15s ease;
}

.customer-entry:active {
  background: #f8f9fa;
}

.entry-arrow {
  margin-left: 8rpx;
  color: #868e96;
}

.footer-slogan {
  text-align: center;
  font-size: 24rpx;
  color: #cccccc;
  margin-top: 32rpx;
  font-weight: 300;
  letter-spacing: 0.5px;
}
