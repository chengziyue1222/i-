.profile-page {
  min-height: 100vh;
  background: #f2f4f8;
  padding-bottom: env(safe-area-inset-bottom);
}

/* 1. 用户信息卡片 (30%) */
.user-card {
  background: linear-gradient(135deg, #0f62fe 0%, #228be6 100%);
  padding: 48rpx 32rpx 40rpx;
  color: #fff;
}

.avatar-btn {
  padding: 0;
  margin: 0;
  background: none;
  border: none;
  line-height: 1;
}

.avatar-btn::after {
  border: none;
}

.user-avatar-wrap {
  margin-bottom: 24rpx;
}

.user-avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255,255,255,0.5);
  display: block;
}

.user-nickname {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.user-manifesto {
  display: block;
  font-size: 26rpx;
  opacity: 0.95;
  margin-bottom: 24rpx;
  line-height: 1.5;
}

.user-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.user-tags .tag {
  padding: 8rpx 20rpx;
  background: rgba(255,255,255,0.25);
  border-radius: 24rpx;
  font-size: 24rpx;
}

/* 2. 数据统计栏 (10%) */
.stats-bar {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: #fff;
  margin: 24rpx;
  padding: 32rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #0f62fe;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 26rpx;
  color: #868e96;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: #e9ecef;
}

/* 3. 功能列表 (50%) */
.func-list {
  margin: 0 24rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.func-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f1f3f5;
}

.func-item:last-child {
  border-bottom: none;
}

.func-item:active {
  background: #f8f9fa;
}

.func-left {
  display: flex;
  align-items: center;
}

.func-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 24rpx;
}

.func-text {
  display: flex;
  flex-direction: column;
}

.func-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #212529;
  margin-bottom: 6rpx;
}

.func-desc {
  font-size: 24rpx;
  color: #868e96;
}

.func-arrow {
  font-size: 40rpx;
  color: #ced4da;
  font-weight: 300;
}

/* 4. 底部区域 (10%) */
.bottom-area {
  padding: 24rpx 32rpx 48rpx;
}

.customer-entry {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  margin-top: 24rpx;
  background: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #495057;
}

.customer-entry:active {
  background: #f8f9fa;
}

.entry-arrow {
  margin-left: 8rpx;
  color: #868e96;
}
