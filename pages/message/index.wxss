page {
  background: #f6f6f6;
  height: 100%;
}

.msg-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(255, 36, 66, 0.06), transparent 28%),
    linear-gradient(180deg, #ffffff 0%, #f6f6f6 28%, #f4f4f4 100%);
}

.msg-tabs {
  display: flex;
  background: rgba(255,255,255,0.94);
  border-bottom: 1rpx solid #ececec;
  flex-shrink: 0;
  padding: 0 24rpx;
}

.msg-tab {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 28rpx 0 20rpx;
  position: relative;
}

.msg-tab-inner {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.msg-tab text {
  font-size: 28rpx;
  color: #868686;
  font-weight: 500;
}

.msg-tab-active text {
  color: #111;
  font-weight: 700;
}

.tab-indicator {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background: #07c160;
  border-radius: 999rpx;
}

.tab-badge {
  min-width: 30rpx;
  height: 30rpx;
  border-radius: 999rpx;
  background: #ff4757;
  color: #fff !important;
  font-size: 18rpx !important;
  line-height: 30rpx;
  text-align: center;
  padding: 0 8rpx;
  position: absolute;
  right: -28rpx;
  top: -10rpx;
}

.msg-list {
  flex: 1;
  height: 0;
  padding: 16rpx 0;
}

.section-title {
  padding: 18rpx 30rpx 12rpx;
  font-size: 22rpx;
  color: #999;
  letter-spacing: 2rpx;
}

.section-gap {
  margin-top: 10rpx;
}

.empty-wrap {
  padding: 120rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.compact-empty {
  padding: 36rpx 0 52rpx;
}

.empty-icon {
  font-size: 76rpx;
}

.empty-text {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #999;
  text-align: center;
  line-height: 1.8;
}

.chat-item {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  background: rgba(255, 255, 255, 0.94);
  border-bottom: 1rpx solid #f0f0f0;
}

.avatar-wrap {
  position: relative;
  margin-right: 22rpx;
}

.avatar {
  width: 92rpx;
  height: 92rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #07c160, #18d06f);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 30rpx rgba(7, 193, 96, 0.18);
}

.avatar-emoji {
  font-size: 38rpx;
}

.badge {
  position: absolute;
  right: -10rpx;
  top: -10rpx;
  min-width: 34rpx;
  height: 34rpx;
  padding: 0 10rpx;
  border-radius: 20rpx;
  background: #ff2442;
  color: #fff;
  font-size: 18rpx;
  line-height: 34rpx;
  text-align: center;
  box-sizing: border-box;
}

.chat-main,
.notify-body,
.apply-body {
  flex: 1;
  min-width: 0;
}

.chat-top,
.notify-top,
.apply-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.chat-name,
.notify-title,
.apply-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #111;
}

.chat-time,
.notify-time,
.apply-time {
  font-size: 22rpx;
  color: #999;
  margin-left: 20rpx;
}

.chat-bottom {
  margin-top: 8rpx;
}

.chat-preview,
.notify-content,
.apply-desc,
.apply-msg {
  font-size: 25rpx;
  color: #777;
  line-height: 1.6;
}

.notify-content {
  display: block;
  margin-top: 8rpx;
}

.chat-preview {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.notify-card,
.notify-item,
.apply-item {
  margin: 0 20rpx 16rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: rgba(255,255,255,0.94);
  display: flex;
  align-items: center;
  position: relative;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.04);
}

.notify-unread {
  background: #fff8fb;
}

.notify-card-plain {
  background: rgba(255,255,255,0.88);
}

.notify-card-success {
  background: #f4fff7;
}

.notify-card-muted {
  background: #fbfbfb;
}

.notify-icon-system {
  background: linear-gradient(135deg, #fff0e1, #fff7ed);
}

.notify-icon,
.apply-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 22rpx;
  text-align: center;
  line-height: 72rpx;
  font-size: 32rpx;
  margin-right: 18rpx;
}

.notify-icon {
  background: linear-gradient(135deg, #ffe5ea, #fff1f3);
}

.apply-avatar {
  background: linear-gradient(135deg, #eefbf3, #f3fff6);
}

.mine-apply-avatar {
  background: linear-gradient(135deg, #eef5ff, #f5f8ff);
}

.apply-avatar-emoji {
  font-size: 34rpx;
}

.apply-top-right {
  display: flex;
  align-items: center;
}

.apply-desc {
  display: block;
  margin-top: 8rpx;
}

.notify-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
}

.notify-chip {
  display: inline-flex;
  align-items: center;
  height: 40rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.notify-chip-mine {
  background: #edf4ff;
  color: #315efb;
}

.notify-chip-apply {
  background: #eefbf3;
  color: #0b8f52;
}

.notify-chip-status {
  background: #fff3e8;
  color: #b96a16;
}

.apply-msg {
  display: block;
  margin-top: 6rpx;
}

.apply-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 18rpx;
}

.apply-btn {
  min-width: 120rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  border-radius: 18rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.apply-reject {
  background: #f3f3f3;
  color: #666;
}

.apply-accept {
  background: linear-gradient(135deg, #07c160, #18d06f);
  color: #fff;
}

.apply-result {
  margin-top: 16rpx;
  font-size: 24rpx;
}

.apply-result-ok {
  color: #07a257;
}

.apply-result-no {
  color: #d85b5b;
}

.apply-result-wait {
  color: #b5822d;
}

.notify-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #ffe5ea, #fff1f3);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 18rpx;
}

.interact-icon-wrap {
  background: linear-gradient(135deg, #fff0f6, #ffd6e7);
}

.dot,
.mini-unread-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #ff2442;
}

.mini-unread-dot {
  width: 12rpx;
  height: 12rpx;
  margin-left: 10rpx;
}
