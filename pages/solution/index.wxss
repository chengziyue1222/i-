page { background:#eef3fb; }
.page { display:flex; flex-direction:column; height:100vh; background:#eef3fb; }

.ai-banner {
  margin:20rpx 24rpx 0;
  background:
    radial-gradient(circle at 18% 15%, rgba(125,206,255,.28) 0%, rgba(125,206,255,0) 35%),
    linear-gradient(135deg,#0c2453 0%,#123a7a 58%,#1451a4 100%);
  border-radius:28rpx;
  padding:34rpx 30rpx;
  display:flex;
  align-items:center;
  justify-content:space-between;
  box-shadow:0 16rpx 36rpx rgba(17,60,124,.35);
}
.ai-left { flex:1; }
.ai-badge {
  display:inline-block;
  font-size:22rpx;
  color:#ffe066;
  background:rgba(255,224,102,.16);
  border:1rpx solid rgba(255,224,102,.34);
  padding:6rpx 16rpx;
  border-radius:999rpx;
  margin-bottom:14rpx;
}
.ai-title { display:block; color:#fff; font-size:40rpx; font-weight:800; line-height:1.35; margin-bottom:8rpx; }
.ai-hint { font-size:22rpx; color:rgba(228,238,255,.78); }
.ai-robot { font-size:84rpx; margin-left:12rpx; filter: drop-shadow(0 6rpx 10rpx rgba(0,0,0,.25)); }

.ai-panel { margin:0 24rpx; background:#fff; border-radius:0 0 24rpx 24rpx; padding:24rpx 24rpx 28rpx; box-shadow:0 12rpx 28rpx rgba(32,76,145,.12); }
.ai-panel-title { display:block; font-size:28rpx; font-weight:700; color:#1b315c; margin-bottom:14rpx; }
.ai-input { background:#f2f6ff; border-radius:14rpx; padding:0 22rpx; height:84rpx; line-height:84rpx; font-size:28rpx; color:#2b3f67; margin-bottom:14rpx; display:block; }
.ai-go { background:linear-gradient(135deg,#1a75ff,#36a2ff); color:#fff; text-align:center; padding:20rpx; border-radius:14rpx; font-size:28rpx; font-weight:700; box-shadow:0 8rpx 20rpx rgba(26,117,255,.32); }
.ai-go:active { opacity:.85; }

.chip-scroll { margin:18rpx 0 0; }
.chip-row { display:flex; gap:12rpx; padding:0 24rpx 6rpx; white-space:nowrap; }
.chip {
  display:inline-flex;
  align-items:center;
  height:62rpx;
  padding:0 24rpx;
  background:#fff;
  color:#647089;
  border-radius:31rpx;
  font-size:25rpx;
  border:2rpx solid #dfe7f5;
  flex-shrink:0;
}
.chip-on {
  background:linear-gradient(135deg,#1a75ff,#36a2ff);
  color:#fff;
  border-color:transparent;
  font-weight:700;
  box-shadow:0 6rpx 14rpx rgba(30,125,255,.28);
}

.list-scroll { flex:1; height:0; }
.waterfall {
  display:flex;
  align-items:flex-start;
  gap:14rpx;
  padding:18rpx 16rpx 120rpx;
}
.waterfall-col {
  flex:1;
  min-width:0;
}

.empty { display:flex; flex-direction:column; align-items:center; padding:90rpx 0; font-size:62rpx; gap:14rpx; }
.empty-t { font-size:26rpx; color:#9aa6bb; }
.list-end { text-align:center; font-size:24rpx; color:#b8c1d2; padding:24rpx 0 42rpx; }

.community-scroll { flex:1; height:0; }
.community-list { padding:20rpx 24rpx 100rpx; display:flex; flex-direction:column; gap:20rpx; }
.post-card { background:#fff; border-radius:20rpx; overflow:hidden; box-shadow:0 4rpx 20rpx rgba(0,0,0,.07); }
.post-cover { height:280rpx; display:flex; align-items:center; justify-content:center; }
.post-emoji { font-size:80rpx; }
.post-body { padding:20rpx 24rpx 24rpx; }
.post-title { display:block; font-size:30rpx; font-weight:700; color:#1a1a1a; margin-bottom:16rpx; line-height:1.5; }
.post-meta { display:flex; align-items:center; justify-content:space-between; margin-bottom:20rpx; }
.post-author { display:flex; align-items:center; gap:10rpx; }
.post-av { width:44rpx; height:44rpx; border-radius:50%; background:linear-gradient(135deg,#0f62fe,#228be6); color:#fff; font-size:20rpx; font-weight:700; display:flex; align-items:center; justify-content:center; }
.post-name { font-size:24rpx; color:#666; }
.post-like { font-size:24rpx; color:#f03e3e; }
.find-btn { background:linear-gradient(135deg,#f5576c,#f093fb); color:#fff; text-align:center; padding:20rpx; border-radius:12rpx; font-size:26rpx; font-weight:600; }
.find-btn:active { opacity:.85; }

.fab {
  position:fixed;
  right:34rpx;
  bottom:124rpx;
  width:108rpx;
  height:108rpx;
  border-radius:50%;
  background:linear-gradient(135deg,#1a75ff,#36a2ff);
  display:flex;
  align-items:center;
  justify-content:center;
  box-shadow:0 12rpx 30rpx rgba(26,117,255,.46);
  z-index:99;
}
.fab:active { transform:scale(.92); }
.fab-icon { color:#fff; font-size:58rpx; font-weight:300; line-height:1; margin-top:-4rpx; }
