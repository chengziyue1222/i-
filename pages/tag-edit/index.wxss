.tag-edit-page {
  min-height: 100vh;
  background: #f2f4f8;
  padding: 24rpx 32rpx 160rpx;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.section-title {
  font-size: 28rpx;
  color: #868e96;
  margin-bottom: 20rpx;
}

.add-row {
  display: flex;
  gap: 20rpx;
}

.add-input {
  flex: 1;
  height: 80rpx;
  padding: 0 24rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  font-size: 28rpx;
  border: 2rpx solid #e9ecef;
}

.add-btn {
  width: 120rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: #0f62fe;
  color: #fff;
  font-size: 28rpx;
  border-radius: 12rpx;
}

.my-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.my-tag {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 20rpx 12rpx 24rpx;
  background: #e7f5ff;
  color: #339af0;
  border-radius: 28rpx;
  font-size: 28rpx;
}

.my-tag .remove {
  margin-left: 12rpx;
  font-size: 36rpx;
  color: #868e96;
}

.empty {
  font-size: 26rpx;
  color: #adb5bd;
}

.preset-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.preset-tag {
  padding: 16rpx 28rpx;
  background: #f1f3f5;
  color: #495057;
  border-radius: 28rpx;
  font-size: 28rpx;
}

.preset-tag.selected {
  background: #e7f5ff;
  color: #339af0;
}

.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
}

.confirm-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #0f62fe;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
}

.confirm-btn::after {
  border: none;
}
