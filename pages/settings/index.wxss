.settings-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f8ff 0%, #eef3fb 100%);
  padding: 24rpx;
}

.section {
  background: rgba(255, 255, 255, 0.96);
  border-radius: 22rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 28rpx rgba(30, 67, 126, 0.08);
}

.section-dev {
  margin-bottom: 24rpx;
  padding: 24rpx;
}

.section-title-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #183153;
}

.section-caption {
  font-size: 22rpx;
  color: #8b9ab2;
}

.api-status-card {
  padding: 22rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #eef5ff, #f8fbff);
  border: 1rpx solid #dce8ff;
  margin-bottom: 18rpx;
}

.api-status-label {
  display: block;
  font-size: 22rpx;
  color: #7a8da9;
}

.api-status-value {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #1c4fa8;
  line-height: 1.6;
  word-break: break-all;
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #edf2f8;
}

.setting-item-block {
  padding: 28rpx 0;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-item:active {
  background: #f8fbff;
}

.item-title {
  display: block;
  font-size: 30rpx;
  color: #212529;
  font-weight: 700;
}

.item-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #8a99af;
  line-height: 1.6;
  word-break: break-all;
}

.item-arrow {
  font-size: 36rpx;
  color: #ced4da;
}

.custom-api-box {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx dashed #dce5f2;
}

.custom-api-label {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: #243a5e;
  margin-bottom: 12rpx;
}

.custom-api-input {
  height: 84rpx;
  border-radius: 16rpx;
  background: #f6f9ff;
  border: 1rpx solid #dce6f6;
  padding: 0 22rpx;
  font-size: 26rpx;
  color: #22334d;
}

.custom-api-btn {
  margin-top: 14rpx;
  height: 78rpx;
  line-height: 78rpx;
  text-align: center;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #0f62fe, #3b94ff);
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
  box-shadow: 0 10rpx 22rpx rgba(15, 98, 254, 0.22);
}

.version-info {
  margin-top: 48rpx;
  text-align: center;
  font-size: 26rpx;
  color: #868e96;
}
