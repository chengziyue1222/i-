page { background: #f2f3f7; height: 100%; }

.cmt-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f2f3f7;
}

.cmt-header {
  background: #fff;
  padding: 24rpx 32rpx 20rpx;
  border-bottom: 1rpx solid #e8eaef;
  flex-shrink: 0;
}

.cmt-post-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a1a;
  display: block;
  margin-bottom: 6rpx;
}

.cmt-count {
  font-size: 22rpx;
  color: #adb5bd;
}

.cmt-list {
  flex: 1;
  height: 0;
  padding: 12rpx 0;
}

.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
  gap: 16rpx;
}
.empty-icon { font-size: 72rpx; }
.empty-text { font-size: 26rpx; color: #adb5bd; text-align: center; line-height: 1.8; }

.cmt-item {
  display: flex;
  align-items: flex-start;
  background: #fff;
  padding: 24rpx 32rpx;
  margin-bottom: 2rpx;
  gap: 18rpx;
}

.cmt-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #e7f5ff, #d0ebff);
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cmt-avatar-emoji {
  display: block;
  width: 72rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  font-size: 32rpx;
}

.cmt-body { flex: 1; min-width: 0; }

.cmt-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.cmt-name { font-size: 26rpx; font-weight: 700; color: #1a1a1a; }
.cmt-time { font-size: 22rpx; color: #adb5bd; }
.cmt-content { font-size: 28rpx; color: #333; line-height: 1.6; }

.list-end {
  text-align: center;
  font-size: 22rpx;
  color: #ced4da;
  padding: 24rpx 0 40rpx;
}

/* ── 输入栏 ── */
.cmt-input-bar {
  flex-shrink: 0;
  background: #fff;
  border-top: 1rpx solid #e8eaef;
  padding: 16rpx 20rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 14rpx;
  box-shadow: 0 -3rpx 14rpx rgba(0,0,0,.05);
}

.cmt-input-wrap {
  flex: 1;
  background: #f2f3f7;
  border: 1.5rpx solid #dee2e6;
  border-radius: 999rpx;
  overflow: hidden;
}

.cmt-input {
  width: 100%;
  height: 76rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #1a1a1a;
  box-sizing: border-box;
}

.cmt-placeholder { color: #adb5bd; font-size: 26rpx; }

.cmt-send-btn {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: #dee2e6;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.cmt-send-btn.cmt-send-active {
  background: linear-gradient(135deg, #0f62fe, #4d94ff);
  box-shadow: 0 6rpx 18rpx rgba(15,98,254,.38);
}

.cmt-send-icon {
  font-size: 34rpx;
  color: #fff;
  font-weight: 700;
  line-height: 1;
  margin-top: -4rpx;
}
