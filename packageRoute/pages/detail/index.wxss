.detail_page {
  padding: 30rpx;
}

.detail_title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.detail_time {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 30rpx;
}

.detail_image {
